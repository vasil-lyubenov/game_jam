  requestDialogue: "\u0412\u044A\u0440\u043D\u0430\u0445 \u0441\u0435 \u0441 \u043D\u043E\u0432\u0438\u043D\u0430.
    \u0418\u043D\u0432\u0435\u0441\u0442\u0438\u0442\u043E\u0440\u0438\u0442\u0435
    \u0438\u0437\u043B\u044F\u0437\u043E\u0445\u0430 \u0441 \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u0435\u043D
    \u043F\u043B\u0430\u043D \u0438 \u043F\u043E\u0435\u0445\u0430 \u0447\u0430\u0441\u0442
    \u043E\u0442 \u0432\u043D\u0435\u0434\u0440\u044F\u0432\u0430\u043D\u0435\u0442\u043E.\n\u0421
    \u0434\u0440\u0443\u0433\u0438 \u0434\u0443\u043C\u0438 \u0440\u0430\u0431\u043E\u0442\u0438.
    \u0423\u0441\u043F\u044F\u0445 \u0434\u0430 \u0443\u0431\u0435\u0434\u044F \u0438\u043D\u0432\u0435\u0441\u0442\u0438\u0442\u043E\u0440\u0438\u0442\u0435,
    \u0438 \u043D\u0438 \u0432\u0440\u044A\u0447\u0438\u0445\u0430 20 000\u20AC!\n\u0429\u0435
    \u043D\u0430\u0437\u043D\u0430\u0447\u0438\u043C \u043E\u0449\u0435 \u0445\u043E\u0440\u0430
