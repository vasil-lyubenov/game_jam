  requestingEmployee: {fileID: 11400000, guid: 17351a82d6e244f75989077cc2356892, type: 2}
  category: 3
  requestDialogue: "\u0417\u0434\u0440\u0430\u0432\u0435\u0439\u0442\u0435. \u0418\u043C\u0430\u043C
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u0437\u0430
    \u0441\u0442\u0430\u0431\u0438\u043B\u0438\u0437\u0438\u0440\u0430\u043D\u0435
    \u043D\u0430 \u0431\u044E\u0434\u0436\u0435\u0442\u0430.\n\n\u0418\u0441\u043A\u0430\u043C
    \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E \u0434\u0430 \u0441\u043F\u0440\u0435\u043C
    \u0431\u043E\u043D\u0443\u0441\u0438\u0442\u0435 \u0438 \u0434\u043E\u043F\u044A\u043B\u043D\u0438\u0442\u0435\u043B\u043D\u0438\u0442\u0435
    \u043F\u0440\u0438\u0434\u043E\u0431\u0438\u0432\u043A\u0438 \u0437\u0430 \u0442\u043E\u0437\u0438
    \u043C\u0435\u0441\u0435\u0446.\n\n\u0429\u0435 \u0441\u043F\u0435\u0441\u0442\u0438\u043C
    \u0434\u043E\u0441\u0442\u0430\u0442\u044A\u0447\u043D\u043E, \u0437\u0430 \u0434\u0430
    \u043D\u0435 \u0440\u0435\u0436\u0435\u043C \u0437\u0430\u043F\u043B\u0430\u0442\u0438
    \u0438 \u0434\u0430 \u043D\u0435 \u0437\u0430\u043A\u0440\u0438\u0432\u0430\u043C\u0435
    \u043F\u043E\u0437\u0438\u0446\u0438\u0438.\n\n\u0414\u0430 \u0433\u043E \u043D\u0430\u043F\u0440\u0430\u0432\u0438\u043C
    \u043B\u0438, \u0438\u043B\u0438 \u043F\u043E\u0435\u043C\u0430\u043C\u0435 \u0440\u0438\u0441\u043A\u0430
    \u0431\u044E\u0434\u0436\u0435\u0442\u044A\u0442 \u0434\u0430 \u043F\u0430\u0434\u043D\u0435
    \u043A\u0440\u0438\u0442\u0438\u0447\u043D\u043E?"
