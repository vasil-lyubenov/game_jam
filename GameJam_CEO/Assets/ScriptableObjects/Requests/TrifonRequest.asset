  requestingEmployee: {fileID: 11400000, guid: a158b485f6b484a74a35dfa5037b5105, type: 2}
  category: 3
  dialogueLines:
  - "\u0417\u0434\u0440\u0430\u0432\u0435\u0439\u0442\u0435. \u041D\u044F\u043C\u0430
    \u0434\u0430 \u0433\u043E \u0443\u0432\u044A\u0440\u0442\u0430\u043C. "
  - "\u0410\u0440\u0442 \u0435\u043A\u0438\u043F\u044A\u0442 \u0435 \u0437\u0430\u0442\u0440\u0443\u043F\u0430\u043D\u2026
    \u0412\u0441\u0438\u0447\u043A\u043E \u0435 \u2018\u0441\u043F\u0435\u0448\u043D\u043E\u2019. "
  - "\u0410\u043A\u043E \u043F\u0440\u043E\u0434\u044A\u043B\u0436\u0438\u043C \u0442\u0430\u043A\u0430,
    \u0438\u043B\u0438 \u0449\u0435 \u043F\u0430\u0434\u043D\u0435 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u043E\u0442\u043E,
    \u0438\u043B\u0438 \u0445\u043E\u0440\u0430\u0442\u0430 \u0449\u0435 \u043F\u0440\u0435\u0433\u043E\u0440\u044F\u0442. "
  - "\u0418\u0441\u043A\u0430\u043C \u0434\u0430 \u043E\u0440\u0435\u0436\u0435\u043C
    \u0447\u0430\u0441\u0442 \u043E\u0442 \u0437\u0430\u0434\u0430\u0447\u0438\u0442\u0435
    \u0438 \u0434\u0430 \u0437\u0430\u043A\u043B\u044E\u0447\u0438\u043C \u0430\u0440\u0442
    \u0441\u0442\u0438\u043B\u0430 \u0437\u0430 \u043E\u0441\u0442\u0430\u0442\u044A\u043A\u0430
    \u043E\u0442 \u043F\u0440\u043E\u0435\u043A\u0442\u0430.  "
  - "\u041E\u0434\u043E\u0431\u0440\u044F\u0432\u0430\u0442\u0435 \u043B\u0438?"
  approveOutcome:
    budgetChange: -5000
    moraleChange: -5
    peopleChange: 0
    employeeHappinessChange: 0
    employeeLeaves: 0
    outcomeText: "\u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F. \u0422\u043E\u0432\u0430
      \u0449\u0435 \u043D\u0438 \u0441\u043F\u0430\u0441\u0438. \u041F\u043E-\u0434\u043E\u0431\u0440\u0435
      \u043F\u043E-\u043C\u0430\u043B\u043A\u043E, \u043D\u043E \u043A\u0430\u043A\u0442\u043E
      \u0442\u0440\u044F\u0431\u0432\u0430."
  denyOutcome:
    budgetChange: -5000
    moraleChange: -5
    peopleChange: 0
    employeeHappinessChange: 0
    employeeLeaves: 0
    outcomeText: "\u042F\u0441\u043D\u043E\u2026 \u0442\u043E\u0433\u0430\u0432\u0430
      \u0449\u0435 '\u0431\u0443\u0442\u0430\u043C\u0435'. \u0421\u0430\u043C\u043E
      \u043D\u0435 \u043C\u0435 \u043F\u0438\u0442\u0430\u0439\u0442\u0435 \u043F\u043E\u0441\u043B\u0435
      \u0437\u0430\u0449\u043E \u043D\u0435 \u0438\u0437\u0433\u043B\u0435\u0436\u0434\u0430
      \u043A\u0430\u0442\u043E \u0432 \u0442\u0440\u0435\u0439\u043B\u044A\u0440\u0430."
