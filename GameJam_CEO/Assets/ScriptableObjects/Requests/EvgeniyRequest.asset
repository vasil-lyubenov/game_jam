  requestingEmployee: {fileID: 11400000, guid: 94a5bde054b9346068abb75ba7d067b6, type: 2}
  category: 4
  requestDialogue: "\u0417\u0434\u0440\u0430\u0432\u0435\u0439\u0442\u0435! \u0418\u043C\u0430\u043C
    \u0435\u0434\u043D\u043E \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435,
    \u043A\u043E\u0435\u0442\u043E \u043C\u043E\u0436\u0435 \u0434\u0430 \u043D\u0438
    \u043F\u043E\u043C\u043E\u0433\u043D\u0435 \u0432 \u0435\u043A\u0438\u043F\u0430.\n\n\u0415\u0434\u0438\u043D
    \u043C\u043E\u0439 \u043F\u0440\u0438\u044F\u0442\u0435\u043B \u0442\u044A\u0440\u0441\u0438
    \u043D\u0435\u043F\u043B\u0430\u0442\u0435\u043D \u0441\u0442\u0430\u0436 \u0438
    \u0435 \u0442\u043E\u0447\u043D\u043E \u0437\u0430 \u043D\u0430\u0448\u0438\u044F
    \u043F\u0440\u043E\u0435\u043A\u0442.\n\n\u041D\u044F\u043C\u0430 \u0434\u0430
    \u0432\u0438 \u0433\u0443\u0431\u044F \u0432\u0440\u0435\u043C\u0435\u0442\u043E
    \u0441\u044A\u0441 CV-\u0442\u0430 \u0438 \u0433\u043B\u0443\u043F\u043E\u0441\u0442\u0438,
    \u0433\u0430\u0440\u0430\u043D\u0442\u0438\u0440\u0430\u043C \u0437\u0430 \u043D\u0435\u0433\u043E.\n\n\u041C\u043E\u0436\u0435
    \u043B\u0438 \u0434\u0430 \u0433\u043E \u0432\u0437\u0435\u043C\u0435\u043C \u0432
    \u0435\u043A\u0438\u043F\u0430? \u0429\u0435 \u0432\u043B\u0435\u0437\u0435 \u0432\u0435\u0434\u043D\u0430\u0433\u0430
    \u0432 \u0440\u0438\u0442\u044A\u043C."
