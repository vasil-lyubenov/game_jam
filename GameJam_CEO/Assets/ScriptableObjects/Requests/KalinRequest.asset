  requestingEmployee: {fileID: 11400000, guid: f29e7d6ac438f47d1afdade42db7fce2, type: 2}
  category: 5
  requestDialogue: "\u0415\u0439, \u0448\u0435\u0444\u0435\u2026 \u0434\u0430 \u0441\u0438
    \u0433\u043E\u0432\u043E\u0440\u0438\u043C \u043A\u0430\u0442\u043E \u043C\u044A\u0436\u0435,
    \u0430? \u0410\u0437 \u0441\u044A\u043C \u043D\u0430\u0439-\u0434\u043E\u0431\u0440\u0438\u044F\u0442
    \u0434\u0435\u0432 \u0442\u0443\u043A\u0430.\n\n\u0418\u043C\u0430\u043C \u043F\u043B\u0430\u043D
    \u043A\u0430\u043A \u0434\u0430 \u0441\u043F\u0435\u0441\u0442\u0438\u043C \u043F\u0430\u0440\u0438.
    \u041C\u0430\u0445\u0430\u0442\u0435 \u0432\u0441\u0438\u0447\u043A\u0438 \u0434\u0440\u0443\u0433\u0438
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u0438\u0441\u0442\u0438.\n\n*\u0425\u043B\u044A\u0446*
    \u041E\u0441\u0442\u0430\u0432\u044F\u0442\u0435 \u0441\u0430\u043C\u043E \u043C\u0435\u043D,
    \u0438 \u0440\u0435\u0430\u043B\u043D\u043E \u0430\u0437 \u0449\u0435 \u0432\u0438
    \u043E\u043F\u0440\u0430\u0432\u044F \u043F\u0440\u043E\u0435\u043A\u0442\u0430.\n\n\u0421\u0442\u0438\u0433\u0430
    \u0441\u043C\u0435 \u0445\u0440\u0430\u043D\u0438\u043B\u0438 \u0447\u0435\u0442\u0438\u0440\u0438\u043C\u0430
    \u0434\u0443\u0448\u0438 \u0437\u0430 \u0440\u0430\u0431\u043E\u0442\u0430, \u043A\u043E\u044F\u0442\u043E
    \u0435\u0434\u0438\u043D \u0447\u0438\u0442\u0430\u0432 \u043C\u043E\u0436\u0435
    \u0434\u0430 \u0441\u0432\u044A\u0440\u0448\u0438.\n\n\u0410\u043A\u043E \u043D\u0435
    \u0441\u0442\u0435 \u0441\u044A\u0433\u043B\u0430\u0441\u043D\u0438\u2026 \u0410\u0437
    \u0441\u0438 \u0442\u0440\u044A\u0433\u0432\u0430\u043C. \u041D\u044F\u043C\u0430
    \u0434\u0430 \u0441\u0435 \u0443\u043D\u0438\u0436\u0430\u0432\u0430\u043C. *\u0425\u043B\u044A\u0446*"
