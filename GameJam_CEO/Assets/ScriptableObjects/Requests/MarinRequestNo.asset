  dialogueLines:
  - "\u0422\u0440\u044F\u0431\u0432\u0430\u0448\u0435 \u0434\u0430 \u0438\u043D\u0432\u0435\u0441\u0442\u0438\u0440\u0430\u043C\u0435.
    \u041F\u0440\u043E\u0437\u043E\u0440\u0435\u0446\u044A\u0442 \u0441\u0435 \u0437\u0430\u0442\u0432\u043E\u0440\u0438. "
  - "\u0427\u0430\u0441\u0442 \u043E\u0442 \u0445\u043E\u0440\u0430\u0442\u0430 \u0433\u043E
    \u043F\u0440\u0438\u0435\u0445\u0430 \u043A\u0430\u0442\u043E \u0437\u043D\u0430\u043A,
    \u0447\u0435 \u043F\u0440\u043E\u0446\u0435\u0441\u044A\u0442 \u043D\u0438\u043A\u043E\u0433\u0430
    \u043D\u044F\u043C\u0430 \u0434\u0430 \u0441\u0442\u0430\u043D\u0435 \u043F\u043E-\u043B\u0435\u043A.  "
  - "\u0412 \u043C\u043E\u043C\u0435\u043D\u0442\u0430 \u043C\u043E\u0440\u0430\u043B\u044A\u0442
    \u043F\u0430\u0434\u0430."
